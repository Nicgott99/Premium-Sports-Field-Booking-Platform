# Strict npm configuration for consistent installs

# Use exact versions (no ^ or ~)
save-exact=false

# Require package-lock.json
require-lock=false

# Set npm registry
registry=https://registry.npmjs.org/

# Set installation timeout
fetch-timeout=60000

# Audit settings
audit=true

# Progress bar
progress=true

# Use exact version when lockfile-version 2
lockfile-version=3
