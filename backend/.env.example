# ============================================
# ENVIRONMENT CONFIGURATION
# ============================================
NODE_ENV=development
PORT=5000

# ============================================
# DATABASE CONFIGURATION
# ============================================
# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/CSE471_Premium_Sports?retryWrites=true&w=majority

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate a secure random string for production
JWT_SECRET=your_ultra_secure_jwt_secret_key_min_32_characters
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# ============================================
# FIREBASE CONFIGURATION
# ============================================
# Get these from Firebase Console > Project Settings
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your_firebase_private_key_with_newlines
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_WEB_API_KEY=AIzaSyA...your_web_api_key

# ============================================
# CLOUDINARY CONFIGURATION (Image Storage)
# ============================================
# Sign up at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ============================================
# STRIPE PAYMENT CONFIGURATION
# ============================================
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_or_sk_live_for_production
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_or_pk_live_for_production
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# ============================================
# EMAIL CONFIGURATION
# ============================================
# Gmail: Enable "App Passwords" for Gmail account
EMAIL_FROM=noreply@yourdomain.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password

# ============================================
# REDIS CONFIGURATION (Caching)
# ============================================
# Local: redis://localhost:6379
# Production: Use managed Redis service
REDIS_URL=redis://localhost:6379

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# Development: http://localhost:3000
# Production: Your deployed URL
CLIENT_URL=http://localhost:3000

# ============================================
# SECURITY CONFIGURATION
# ============================================
# Number of salt rounds for bcrypt (10-12 recommended)
BCRYPT_SALT_ROUNDS=12
SESSION_SECRET=your_ultra_secure_session_secret_min_32_characters

# ============================================
# RATE LIMITING
# ============================================
# Window in milliseconds (15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000
# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug
